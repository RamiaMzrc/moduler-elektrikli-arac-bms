<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- APP BAR (Sticky Top Header) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Batarya İzleme Paneli"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- ADM Admin Badge -->
            <LinearLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_badge"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADM"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modüler Elektrikli Araç ve Enerji Depolama Sitemi"
            android:textColor="#E0E7FF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- CONTENT BODY (Scrollable) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TECHNICAL CONSTANTS CARD (Compact Grid Style) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SİSTEM TEKNİK PARAMETRELERİ"
                    android:textColor="@color/slate_500"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <!-- 2-Column Param Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <!-- Column 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KİMYA"
                            android:textColor="@color/slate_500"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="LFP (Lityum Demir)"
                            android:textColor="@color/slate_800"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="İDEAL ÇALIŞMA SICAKLIĞI"
                            android:textColor="@color/slate_500"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25°C"
                            android:textColor="@color/slate_800"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KULOMBİK VERİMLİLİK"
                            android:textColor="@color/slate_500"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%99.9"
                            android:textColor="@color/slate_800"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Column 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="KAPASİTE"
                            android:textColor="@color/slate_500"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="29 kWh"
                            android:textColor="@color/slate_800"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ENERJİ VERİMLİLİĞİ"
                            android:textColor="@color/slate_500"
                            android:textSize="9sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="%92 - %95"
                            android:textColor="@color/slate_800"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 2x2 GRID OF REAL-TIME METRICS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <!-- GERİLİM CARD -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/card_bg"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginEnd="6dp"
                        android:elevation="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gerilim"
                            android:textColor="@color/slate_500"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tv_voltage_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="360.0"
                                android:textColor="@color/slate_800"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" V"
                                android:textColor="@color/slate_400"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- AKIM CARD -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/card_bg"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginStart="6dp"
                        android:elevation="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Akım"
                            android:textColor="@color/slate_500"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tv_current_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12.5"
                                android:textColor="@color/slate_800"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" A"
                                android:textColor="@color/slate_400"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- SICAKLIK CARD -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/card_bg"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginEnd="6dp"
                        android:elevation="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sıcaklık"
                            android:textColor="@color/slate_500"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="bottom"
                            android:layout_marginTop="8dp">

                            <TextView
                                android:id="@+id/tv_temp_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="25.0"
                                android:textColor="@color/slate_800"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" °C"
                                android:textColor="@color/slate_400"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- GÜVENLİK KİLİDİ (KİLİT DURUMU) CARD -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/card_bg"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:layout_marginStart="6dp"
                        android:elevation="1dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kilit Durumu"
                            android:textColor="@color/slate_500"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <!-- Indicator Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="14dp">

                            <View
                                android:id="@+id/v_lock_indicator"
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/dot_green"
                                android:layout_marginEnd="8dp" />

                            <TextView
                                android:id="@+id/tv_lock_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PASİF"
                                android:textColor="@color/normal_green"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- SOC CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Şarj Durumu (SOC)"
                        android:textColor="@color/slate_700"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_soc_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="%76"
                        android:textColor="@color/normal_green"
                        android:textSize="18sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/pb_soc"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="10dp"
                    android:layout_marginTop="12dp"
                    android:max="100"
                    android:progress="76"
                    android:progressDrawable="@android:drawable/progress_horizontal" />
            </LinearLayout>

            <!-- SYSTEM STATUS BLOCK -->
            <LinearLayout
                android:id="@+id/ll_status_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/status_normal_bg"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="20dp"
                android:elevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Indicator visual ring -->
                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/circle_badge"
                        android:backgroundTint="@color/normal_green"
                        android:gravity="center"
                        android:layout_marginEnd="12dp">
                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="@drawable/circle_badge"
                            android:backgroundTint="@color/white" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_status_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SİSTEM DURUMU: NORMAL"
                            android:textColor="@color/slate_800"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Güvenlik Kontrolü: Doğrulandı"
                            android:textColor="@color/slate_500"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D1D5DB"
                    android:layout_marginVertical="12dp" />

                <TextView
                    android:id="@+id/tv_warning_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sistem stabil. Tüm değerler güvenli aralıkta."
                    android:textColor="@color/slate_800"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- MANUAL TEST ACTIONS BUTTON CABINET -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="16dp"
                android:elevation="1dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manüel Durum Testleri"
                    android:textColor="@color/slate_500"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_test_normal"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Normal"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_bg"
                        android:backgroundTint="@color/normal_green"
                        android:layout_marginEnd="4dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_test_warning"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Uyarı"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_bg"
                        android:backgroundTint="@color/warning_orange"
                        android:layout_marginHorizontal="4dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_test_fault"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Hata"
                        android:textSize="12sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_bg"
                        android:backgroundTint="@color/fault_red"
                        android:layout_marginStart="4dp"
                        android:textAllCaps="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- SYSTEM CONTROLS CABINET (Footer Controls) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <Button
                        android:id="@+id/btn_start_sim"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1.3"
                        android:text="Simülasyonu Başlat"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_bg"
                        android:backgroundTint="@color/primary"
                        android:layout_marginEnd="6dp"
                        android:textAllCaps="false" />

                    <Button
                        android:id="@+id/btn_stop_sim"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1.3"
                        android:text="Simülasyonu Durdur"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:background="@drawable/button_bg"
                        android:backgroundTint="@color/slate_500"
                        android:layout_marginStart="6dp"
                        android:textAllCaps="false" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Çıkış Yap"
                    android:textSize="13sp"
                    android:textColor="@color/slate_700"
                    android:background="@drawable/card_bg"
                    android:textAllCaps="false" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
