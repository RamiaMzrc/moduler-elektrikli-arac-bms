<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8F6">
    
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Batarya İzleme Paneli"
            android:textColor="#1B5E20"
            android:textSize="28sp"
            android:textStyle="bold" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/txtStatus"
            android:background="#2E7D32"
            android:gravity="center"
            android:padding="14dp"
            android:text="NORMAL"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />
        <ProgressBar
            android:layout_width="match_parent"
            android:layout_height="28dp"
            android:id="@+id/progressSoc"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_marginTop="20dp"
            android:max="100"
            android:progress="76" />
        <TextView
            android:id="@+id/txtSoc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="SOC: 76%"
            android:textSize="22sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtVoltage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Voltaj: 48.2 V"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtCurrent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Akım: 12.5 A"
            android:textSize="18sp" />
        <TextView
            android:id="@+id/txtTemperature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Sıcaklık: 34.7 °C"
            android:textSize="18sp" />
        <TextView
            android:id="@+id/txtWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="#E8F5E9"
            android:padding="14dp"
            android:text="Uyarı: Yok"
            android:textColor="#2E7D32"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/txtStation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="#E3F2FD"
            android:padding="14dp"
            android:text="Swap İstasyonu: Gerekli değil"
            android:textColor="#1565C0"
            android:textSize="16sp"
            android:textStyle="bold" />
        <Button
            android:id="@+id/btnNormal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="NORMAL" />
        <Button
            android:id="@+id/btnWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WARNING" />
        <Button
            android:id="@+id/btnFault"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FAULT" />
        <Button
            android:id="@+id/btnSwapComplete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BATARYA DEĞİŞTİRİLDİ" />

    </LinearLayout>
</ScrollView>
        